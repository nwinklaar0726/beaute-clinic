# ──────────────────────────────────────────────────
#  Dental Bot — Environment Variables
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# ── Meta / WhatsApp Cloud API ──────────────────────
# Webhook verify token (choose any string, set same in Meta dashboard)
META_VERIFY_TOKEN=my_secure_verify_token

# Meta App Secret (used for X-Hub-Signature-256 verification)
META_APP_SECRET=your_meta_app_secret

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── Instagram Graph API ────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_instagram_page_access_token
INSTAGRAM_PAGE_ID=your_instagram_page_id

# ── Google Calendar API (OAuth2) ───────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://yourapp.com/oauth/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
# Use 'primary' for the account's main calendar or paste a specific calendar ID
GOOGLE_CALENDAR_ID=primary

# ── PostgreSQL ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dental_bot
DB_USER=postgres
DB_PASSWORD=yourpassword
# Set to 'true' when connecting to Neon / Supabase / RDS with SSL
DB_SSL=false

# ── Clinic Settings ────────────────────────────────
CLINIC_NAME=Consultorio Dental
DOCTOR_NAME=Dr. García
TIMEZONE=America/Costa_Rica
# Working hours (24-hour format, integers)
WORKING_HOURS_START=8
WORKING_HOURS_END=17
# Duration per appointment slot in minutes
APPOINTMENT_DURATION=60

# ── Admin Panel Authentication ─────────────────────
# Username and password for accessing the admin panel
# If not set, the panel will be accessible without authentication (not recommended for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
